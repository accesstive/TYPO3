{
    "name": "accesstive/typo3",
    "type": "typo3-cms-extension",
    "description": "Accesstive is an all-in-one accessibility platform that helps websites become inclusive, compliant, and user-friendly.",
    "keywords": [
        "typo3",
        "cms",
        "accessibility",
        "compliance",
        "widget"
    ],
    "homepage": "https://accesstive.com",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Accesstive",
            "email": "support@accesstive.com",
            "role": "Developer"
        }
    ],
    "require": {
        "typo3/cms-core": "^10.4 || ^11.5 || ^12.4 || ^13.0",
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Accesstive\\Accesstive\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "accesstive"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
} 
